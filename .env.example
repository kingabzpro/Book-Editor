# ─── Nebius API (required) ────────────────────────────────────────────────────
NEBIUS_API_KEY=your_nebius_key_here
NEBIUS_BASE_URL=https://api.studio.nebius.com/v1/

# ─── Models (check https://studio.nebius.com for available model IDs) ────────
# Fast model — used for rewriting and editing
KIMI_MODEL=moonshotai/Kimi-K2.5-fast

# Analysis model — used for Bible generation and structure analysis
GLM_MODEL=zai-org/GLM-5

# ─── Rewrite settings ─────────────────────────────────────────────────────────
TARGET_MIN=2000
TARGET_MAX=3500

# ─── Context window ───────────────────────────────────────────────────────────
# How many chapters before/after to include when rewriting
PREV_CHAPTERS=2
NEXT_CHAPTERS=1
